{
  "version": 2,
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 60,
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "STREAMLIT_SERVER_HEADLESS": "true"
  }
}
